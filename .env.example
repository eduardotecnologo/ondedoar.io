# ============================================
# Variáveis de ambiente - ondedoar.io
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais
# ============================================

# Banco de dados (PostgreSQL / Supabase)
DATABASE_URL="postgresql://usuario:senha@host:porta/banco?schema=public"

# Supabase (opcional, se usado no futuro)
NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"

# NextAuth
NEXTAUTH_SECRET="uma-string-secreta-e-longa"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin
ADMIN_EMAIL="seu-email@exemplo.com"

# URL pública da aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"
