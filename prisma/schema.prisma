generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome          String?
  email         String?       @unique
  email_verificado_em DateTime? @db.Timestamptz(6)
  password      String?
  image         String?
  criado_em     DateTime      @default(now()) @db.Timestamptz(6)
  atualizado_em DateTime?     @updatedAt @db.Timestamptz(6)
  pontos        PontoColeta[]
  reset_tokens  PasswordResetToken[]
  interdicoes   RuaInterditada[]

  @@map("users")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  criado_em  DateTime  @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([expires_at])
  @@map("password_reset_tokens")
}

model TipoDoacao {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome             String           @unique(map: "categorias_nome_unique")
  icone            String?
  ponto_categorias PontoCategoria[]

  @@map("categorias")
}

model PontoColeta {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome             String
  descricao        String?
  status_doacao    String?
  status_auto_ativar_em   DateTime?      @db.Timestamptz(6)
  status_auto_inativar_em DateTime?      @db.Timestamptz(6)
  cep              String?
  endereco         String
  numero           String
  cidade           String
  estado           String
  latitude         Float?
  longitude        Float?
  telefone         String?
  whatsapp         String?
  voluntario_especialidades       String?
  voluntario_contato_agendamento  String?
  voluntario_disponivel           Boolean?
  fraldas_publico                 String?
  criado_em        DateTime?        @default(now()) @db.Timestamptz(6)
  user_id          String?          @db.Uuid
  ponto_categorias PontoCategoria[]
  user             User?            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("pontos_coleta")
}

model PontoCategoria {
  ponto_id      String      @db.Uuid
  categoria_id  String      @db.Uuid
  categorias    TipoDoacao  @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pontos_coleta PontoColeta @relation(fields: [ponto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([ponto_id, categoria_id])
  @@map("ponto_categorias")
}

model RuaInterditada {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rua         String
  numero      String?
  cidade      String
  estado      String
  referencia  String?
  motivo      String?
  foto_motivo String?
  ativa       Boolean   @default(true)
  latitude    Float?
  longitude   Float?
  criado_em   DateTime  @default(now()) @db.Timestamptz(6)
  atualizado_em DateTime? @updatedAt @db.Timestamptz(6)
  user_id     String?   @db.Uuid
  user        User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cidade, estado])
  @@index([ativa])
  @@map("ruas_interditadas")
}

model PedidoAjuda {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome         String
  contato      String
  cidade       String
  estado       String
  categoria    String    @default("OUTRO")
  descricao    String
  urgencia     String    @default("MEDIA")
  status       String    @default("ABERTO")
  anonimo      Boolean   @default(false)
  atendido_por_nome    String?
  atendido_por_anonimo Boolean   @default(false)
  atendido_em          DateTime? @db.Timestamptz(6)
  criado_em    DateTime  @default(now()) @db.Timestamptz(6)
  atualizado_em DateTime? @db.Timestamptz(6)

  @@index([status])
  @@index([cidade, estado])
  @@map("pedidos_ajuda")
}
