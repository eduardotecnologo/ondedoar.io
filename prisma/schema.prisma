generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome          String?
  email         String?       @unique
  password      String?
  image         String?
  criado_em     DateTime      @default(now()) @db.Timestamptz(6)
  atualizado_em DateTime?     @updatedAt @db.Timestamptz(6)
  pontos        PontoColeta[]

  @@map("users")
}

model TipoDoacao {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome             String           @unique(map: "categorias_nome_unique")
  icone            String?
  ponto_categorias PontoCategoria[]

  @@map("categorias")
}

model PontoColeta {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome             String
  descricao        String?
  endereco         String
  numero           String
  cidade           String
  estado           String
  latitude         Float?
  longitude        Float?
  telefone         String?
  whatsapp         String?
  criado_em        DateTime?        @default(now()) @db.Timestamptz(6)
  user_id          String?          @db.Uuid
  ponto_categorias PontoCategoria[]
  user             User?            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("pontos_coleta")
}

model PontoCategoria {
  ponto_id      String      @db.Uuid
  categoria_id  String      @db.Uuid
  categorias    TipoDoacao  @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pontos_coleta PontoColeta @relation(fields: [ponto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([ponto_id, categoria_id])
  @@map("ponto_categorias")
}
